{
  "name": "model-agnostic-workflow-system",
  "version": "0.2.1",
  "private": true,
  "description": "Provider-neutral shared-core scaffold with Codex compatibility export.",
  "type": "module",
  "scripts": {
    "validate": "node scripts/tools/validate-repo-surface.mjs",
    "check": "node scripts/tools/validate-repo-surface.mjs",
    "snake:dev": "node scripts/tools/serve-snake.mjs",
    "snake:test": "node --test examples/snake/snake.test.mjs",
    "build-registry": "node scripts/tools/build-neutral-core-registry.mjs --write",
    "build-exports": "node scripts/tools/build-provider-exports.mjs --write",
    "validate-neutral": "node scripts/tools/validate-provider-neutral-core.mjs",
    "eval": "node scripts/tools/run-certification-evals.mjs",
    "eval:skill-routing": "node scripts/tools/run-certification-evals.mjs --kind skill-routing",
    "detect-skill-overlap": "node scripts/tools/detect-skill-overlap.mjs --json",
    "lint-skill-contracts": "node scripts/tools/lint-skill-contracts.mjs --json",
    "analyze-skill-tree-coverage": "node scripts/tools/analyze-skill-tree-coverage.mjs --json",
    "fingerprint": "node scripts/tools/calculate-package-fingerprint.mjs",
    "refresh-lock": "node scripts/tools/refresh-consumer-lock.mjs",
    "validate-consumer": "node scripts/tools/validate-consumer-linkage.mjs",
    "validate-input-contract": "node scripts/tools/validate-local-input-contract.mjs",
    "validate-runtime-policy-input-contract": "node scripts/tools/validate-runtime-policy-input-contract.mjs",
    "init-consumer": "node scripts/tools/init-consumer-overlay.mjs",
    "init-qwen-bootstrap": "node scripts/tools/init-qwen-bootstrap.mjs",
    "validate-qwen-bootstrap": "node scripts/tools/validate-qwen-bootstrap.mjs",
    "scan": "node scripts/tools/repo-structure-scanner.mjs",
    "diff": "node scripts/tools/git-diff-explainer.mjs",
    "analyze-content-semantics-for-design": "node scripts/tools/analyze-content-semantics-for-design.mjs --json",
    "generate-visual-direction-contract": "node scripts/tools/generate-visual-direction-contract.mjs --json",
    "lint-semantic-design-contracts": "node scripts/tools/lint-semantic-design-contracts.mjs --json",
    "derive-oklch-palette": "node scripts/tools/derive-oklch-palette.mjs --json",
    "eval:semantic-layout": "node scripts/tools/run-certification-evals.mjs --kind semantic-layout"
  }
