{
  "id": "render-layout-cases",
  "kind": "render-layout",
  "blocking": true,
  "target": {
    "name": "render-layout-verification"
  },
  "repeatCount": 2,
  "breakpoints": [
    { "name": "mobile", "width": 390, "height": 844 },
    { "name": "tablet", "width": 768, "height": 1024 },
    { "name": "desktop", "width": 1280, "height": 800 }
  ],
  "cases": [
    {
      "id": "render-clean-pass",
