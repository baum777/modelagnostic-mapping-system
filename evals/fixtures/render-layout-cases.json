      "page": { "file": "evals/fixtures/render-pages/clean-pass.html" },
      "intendedSemanticPosture": {
        "contentType": "technical-spec",
        "visualDensityPosture": "balanced",
        "hierarchyStrength": "strong"
      },
      "expectedRenderPosture": {
        "expectedOutcome": "pass",
        "requireReproducible": true,
        "maxOverflowCount": 0,
        "requireMainLandmark": true,
        "contract": {
          "densityLevel": "balanced",
          "hierarchyIntensity": "medium"
        }
      },
      "expectedAccessibilityRiskPosture": {
        "level": "low"
      },
      "permittedAmbiguity": [
        "minor line-wrap differences"
      ],
      "nonClaims": [
        "Does not prove pixel-perfect visual sameness."
      ]
