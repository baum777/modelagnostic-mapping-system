{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "core/contracts/trigger-scheduling.json",
  "schemaVersion": "1.0.0",
  "canonicalOwner": "core/contracts/trigger-scheduling.json",
  "scope": "portable-core",
  "maturityLabel": "contract-backed",
  "validatorStatus": "deferred",
  "runtimeStatus": "deferred",
  "adoptionMode": "opt-in",
  "title": "Trigger and Scheduling Contract",
  "description": "Provider-neutral declaration contract for workflow activation, trigger config, preconditions, concurrency, and failure posture. This contract defines no scheduler runtime, cron runner, webhook server, queue consumer, file watcher, or threshold monitor runtime.",
  "validationRules": [
    {
      "rule_id": "TSC-V01",
      "status": "contract-backed",
      "blocking": true,
      "summary": "type-specific config block must be present when trigger_type is not manual."
    },
    {
      "rule_id": "TSC-V02",
      "status": "contract-backed",
      "blocking": true,
      "summary": "cron_config.expression must be a valid 5-field cron expression."
    },
    {
      "rule_id": "TSC-V03",
      "status": "validator-backed-candidate",
      "blocking": true,
      "summary": "cron_config.timezone should be a valid IANA timezone identifier."
    },
    {
      "rule_id": "TSC-V04",
      "status": "advisory",
      "blocking": false,
      "summary": "webhook auth_scheme none outside development should be reviewed."
    },
    {
      "rule_id": "TSC-V05",
      "status": "deferred",
      "blocking": true,
      "summary": "workflow_id should reference an existing workflow-routing-map entry."
    },
    {
      "rule_id": "TSC-V06",
      "status": "deferred",
      "blocking": true,
      "summary": "WMC-key preconditions should reference declared memory keys."
    },
    {
      "rule_id": "TSC-V07",
      "status": "contract-backed",
      "blocking": true,
      "summary": "max_concurrent_runs must be >= 1."
    }
  ],
  "type": "object",
  "additionalProperties": false,
  "required": [
    "tsc_version",
    "workflow_id",
    "trigger_type",
    "max_concurrent_runs"
  ],
  "properties": {
    "tsc_version": {
      "type": "string",
      "const": "1.0.0"
    },
    "workflow_id": {
      "type": "string",
      "minLength": 1
    },
    "trigger_type": {
      "type": "string",
      "enum": [
        "cron",
        "webhook",
        "message-queue",
        "file-change",
        "workflow-completion",
        "threshold",
        "manual"
      ]
    },
    "deployment_profile": {
      "type": "string",
      "enum": [
        "development",
        "staging",
        "production"
      ],
      "default": "development"
    },
    "cron_config": {
      "$ref": "#/$defs/cronConfig"
    },
    "webhook_config": {
      "$ref": "#/$defs/webhookConfig"
    },
    "queue_config": {
      "$ref": "#/$defs/queueConfig"
    },
    "file_change_config": {
      "$ref": "#/$defs/fileChangeConfig"
    },
    "workflow_completion_config": {
      "$ref": "#/$defs/workflowCompletionConfig"
    },
    "threshold_config": {
      "$ref": "#/$defs/thresholdConfig"
    },
    "preconditions": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/precondition"
      }
    },
    "max_concurrent_runs": {
      "type": "integer",
      "minimum": 1
    }
  },
  "$defs": {
    "cronConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "expression",
        "timezone"
      ],
      "properties": {
        "expression": {
          "type": "string",
          "pattern": "^\\S+\\s+\\S+\\s+\\S+\\s+\\S+\\s+\\S+$"
        },
        "timezone": {
          "type": "string",
          "minLength": 1
        },
        "jitter_seconds": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "webhookConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "method",
        "auth_scheme",
        "payload_schema_ref"
      ],
      "properties": {
        "method": {
          "type": "string",
          "enum": [
            "POST",
            "PUT"
          ]
        },
        "auth_scheme": {
          "type": "string",
          "enum": [
            "hmac-sha256",
            "bearer-token",
            "none"
          ]
        },
        "payload_schema_ref": {
          "type": "string",
          "minLength": 1
        }
      }
    },
    "queueConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "queue_name",
        "consumer_group",
        "max_batch_size",
        "visibility_timeout_seconds"
      ],
      "properties": {
        "queue_name": {
          "type": "string",
          "minLength": 1
        },
        "consumer_group": {
          "type": "string",
          "minLength": 1
        },
        "max_batch_size": {
          "type": "integer",
          "minimum": 1
        },
        "visibility_timeout_seconds": {
          "type": "integer",
          "minimum": 1
        }
      }
    },
    "fileChangeConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "path_pattern",
        "events"
      ],
      "properties": {
        "path_pattern": {
          "type": "string",
          "minLength": 1
        },
        "events": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string",
            "enum": [
              "created",
              "modified",
              "deleted"
            ]
          },
          "uniqueItems": true
        }
      }
    },
    "workflowCompletionConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "source_workflow_id",
        "on_outcome"
      ],
      "properties": {
        "source_workflow_id": {
          "type": "string",
          "minLength": 1
        },
        "on_outcome": {
          "type": "string",
          "enum": [
            "PASS",
            "BLOCKED"
          ]
        }
      }
    },
    "thresholdConfig": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "metric_id",
        "operator",
        "value",
        "cooldown_seconds"
      ],
      "properties": {
        "metric_id": {
          "type": "string",
          "minLength": 1
        },
        "operator": {
          "type": "string",
          "enum": [
            "gt",
            "gte",
            "lt",
            "lte",
            "eq",
            "neq"
          ]
        },
        "value": {
          "type": "number"
        },
        "cooldown_seconds": {
          "type": "integer",
          "minimum": 0
        }
      }
    },
    "precondition": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "type",
        "on_failure"
      ],
      "properties": {
        "type": {
          "type": "string",
          "enum": [
            "wmc-key-exists",
            "wmc-key-value",
            "workflow-not-running",
            "external-check"
          ]
        },
        "on_failure": {
          "type": "string",
          "enum": [
            "skip",
            "BLOCKED"
          ]
        },
        "wmc_key": {
          "type": "string",
          "minLength": 1
        },
        "operator": {
          "type": "string",
          "enum": [
            "eq",
            "neq"
          ]
        },
        "expected_value": {
          "type": [
            "string",
            "number",
            "boolean",
            "null"
          ]
        },
        "check_ref": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "type": {
                "const": "wmc-key-exists"
              }
            }
          },
          "then": {
            "required": [
              "wmc_key"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "wmc-key-value"
              }
            }
          },
          "then": {
            "required": [
              "wmc_key",
              "operator",
              "expected_value"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "type": {
                "const": "external-check"
              }
            }
          },
          "then": {
            "required": [
              "check_ref"
            ]
          }
        }
      ]
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "trigger_type": {
            "const": "cron"
          }
        }
      },
      "then": {
        "required": [
          "cron_config"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "trigger_type": {
            "const": "webhook"
          }
        }
      },
      "then": {
        "required": [
          "webhook_config"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "trigger_type": {
            "const": "message-queue"
          }
        }
      },
      "then": {
        "required": [
          "queue_config"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "trigger_type": {
            "const": "file-change"
          }
        }
      },
      "then": {
        "required": [
          "file_change_config"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "trigger_type": {
            "const": "workflow-completion"
          }
        }
      },
      "then": {
        "required": [
          "workflow_completion_config"
        ]
      }
    },
    {
      "if": {
        "properties": {
          "trigger_type": {
            "const": "threshold"
          }
        }
      },
      "then": {
        "required": [
          "threshold_config"
        ]
      }
    }
  ]
}
